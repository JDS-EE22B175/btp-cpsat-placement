      "source": [
        "# CP-SAT Detailed Placer\n",
        "This notebook implements a detailed placement optimizer using OR-Tools. It minimizes HPWL and occupied area while strictly adhering to core boundaries, site rows, and fixed infrastructure obstacles."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 1,
      "metadata": {},
      "outputs": [],
      "source": [
        "import sys\n",
        "import time\n",
        "import LEFDEFParser\n",
        "import os\n",
        "import subprocess\n",
        "from ortools.sat.python import cp_model\n",
        "\n",
        "# --- Progress Callback Class ---\n",
        "class PlacementCallback(cp_model.CpSolverSolutionCallback):\n",
        "    def __init__(self):\n",
        "        cp_model.CpSolverSolutionCallback.__init__(self)\n",
        "        self._solution_count = 0\n",
        "        self._start_time = time.time()\n",
        "\n",
        "    def on_solution_callback(self):\n",
        "        self._solution_count += 1\n",
        "        print(f\"[{time.time() - self._start_time:.2f}s] Solution {self._solution_count}: \"\n",
        "              f\"Current Objective = {self.ObjectiveValue()}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 2,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Parsed design. Chip BBox: (0,0) to (187035, 197755)\n"
          ]
        }
      ],
      "source": [
        "# --- Initialization & Parsing ---\n",
        "deffile = \"../deffiles/project/def/c7552.def\"\n",
        "leffile = \"../leffiles/sky130.lef\"\n",
        "outfile = \"../outputDefs/project/def/c7552_placed.def\"\n",
        "\n",
        "d_parser = LEFDEFParser.DEFReader()\n",
        "d_parser.readDEF(deffile)\n",
        "l_parser = LEFDEFParser.LEFReader()\n",
        "l_parser.readLEF(leffile)\n",
        "\n",
        "dimLookup = {m.name(): (m.xdim(), m.ydim()) for m in l_parser.macros()}\n",
        "site_height = 2720 # Sky130 Row Height\n",
        "\n",
        "chip_bbox = d_parser.bbox()\n",
        "x_max = chip_bbox.ur.x\n",
        "y_max = chip_bbox.ur.y\n",
        "print(f\"Parsed design. Chip BBox: (0,0) to ({x_max}, {y_max})\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Extracted Core Zone: X(6900 to 179860), Y(10880 to 182240)\n"
          ]
        }
      ],
      "source": [
        "# --- Dynamic Core Boundary Extraction ---\n",
        "left_edge_coords = []\n",
        "right_edge_coords = []\n",
        "y_coords = []\n",
        "\n",
        "for comp in d_parser.components():\n",
        "    name = comp.name()\n",
        "    if \"Left\" in name:\n",
        "        w, _ = dimLookup[comp.macro()]\n",
        "        left_edge_coords.append(comp.location().x + w)\n",
        "    elif \"Right\" in name:\n",
        "        right_edge_coords.append(comp.location().x)\n",
        "    \n",
        "    if \"PHY_EDGE\" in name or \"TAP\" in name:\n",
        "        y_coords.append(comp.location().y)\n",
        "\n",
        "core_x_min = max(left_edge_coords) if left_edge_coords else 0\n",
        "core_x_max = min(right_edge_coords) if right_edge_coords else x_max\n",
        "core_y_min = min(y_coords) if y_coords else 0\n",
        "core_y_max = max(y_coords) if y_coords else y_max\n",
        "\n",
        "print(f\"Extracted Core Zone: X({core_x_min} to {core_x_max}), Y({core_y_min} to {core_y_max})\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Added 1424 movable gates and 557 fixed obstacles.\n"
          ]
        }
      ],
      "source": [
        "# --- Model & Variables (Nodes and Obstacles) ---\n",
        "model = cp_model.CpModel()\n",
        "nodes = {}\n",
        "x_intervals = []\n",
        "y_intervals = []\n",
        "\n",
        "for comp in d_parser.components():\n",
        "    c_name = comp.name()\n",
        "    w, h = dimLookup[comp.macro()]\n",
        "    loc = comp.location()\n",
        "\n",
        "    # 1. Fixed Infrastructure (Obstacles)\n",
        "    if c_name.startswith(\"TAP_\") or c_name.startswith(\"PHY_EDGE_\"):\n",
        "        x_int = model.NewFixedSizeIntervalVar(loc.x, w, f'fixed_x_{c_name}')\n",
        "        y_int = model.NewFixedSizeIntervalVar(loc.y, h, f'fixed_y_{c_name}')\n",
        "        x_intervals.append(x_int)\n",
        "        y_intervals.append(y_int)\n",
        "        continue \n",
        "\n",
        "    # 2. Movable Logic Gates\n",
        "    x_var = model.new_int_var(core_x_min, core_x_max - w, f\"x_{c_name}\")\n",
        "    num_rows = (core_y_max - core_y_min) // site_height + 1\n",
        "    row_idx = model.new_int_var(0, num_rows - 1, f\"row_{c_name}\")\n",
        "    y_var = model.new_int_var(core_y_min, core_y_max, f\"y_{c_name}\")\n",
        "    \n",
        "    # Site alignment constraint\n",
        "    model.add(y_var == core_y_min + (row_idx * site_height))\n",
        "\n",
        "    x_int = model.NewIntervalVar(x_var, w, x_var + w, f'x_int_{c_name}')\n",
        "    y_int = model.NewIntervalVar(y_var, h, y_var + h, f'y_int_{c_name}')\n",
        "    x_intervals.append(x_int)\n",
        "    y_intervals.append(y_int)\n",
        "    \n",
        "    nodes[c_name] = {'x': x_var, 'y': y_var, 'w': w, 'h': h}\n",
        "\n",
        "# Hard Legality Constraint: No overlaps for ANY interval\n",
        "model.add_no_overlap_2d(x_intervals, y_intervals)\n",
        "print(f\"Added {len(nodes)} movable gates and {len(x_intervals) - len(nodes)} fixed obstacles.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 5,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Objectives added.\n"
          ]
        }
      ],
      "source": [
        "# --- Objectives (HPWL & Area Span) ---\n",
        "net_costs = []\n",
        "for net in d_parser.nets():\n",
        "    pin_x_vars = [nodes[p[0]]['x'] for p in net.pins() if p[0] in nodes]\n",
        "    pin_y_vars = [nodes[p[0]]['y'] for p in net.pins() if p[0] in nodes]\n",
        "    if len(pin_x_vars) < 2: continue\n",
        "    \n",
        "    min_x = model.new_int_var(core_x_min, core_x_max, f\"min_x_{net.name()}\")\n",
        "    max_x = model.new_int_var(core_x_min, core_x_max, f\"max_x_{net.name()}\")\n",
        "    model.add_min_equality(min_x, pin_x_vars)\n",
        "    model.add_max_equality(max_x, pin_x_vars)\n",
        "    \n",
        "    min_y = model.new_int_var(core_y_min, core_y_max, f\"min_y_{net.name()}\")\n",
        "    max_y = model.new_int_var(core_y_min, core_y_max, f\"max_y_{net.name()}\")\n",
        "    model.add_min_equality(min_y, pin_y_vars)\n",
        "    model.add_max_equality(max_y, pin_y_vars)\n",
        "    \n",
        "    net_costs.append((max_x - min_x) + (max_y - min_y))\n",
        "\n",
        "g_min_x = model.new_int_var(core_x_min, core_x_max, \"g_min_x\")\n",
        "g_max_x = model.new_int_var(core_x_min, core_x_max, \"g_max_x\")\n",
        "g_min_y = model.new_int_var(core_y_min, core_y_max, \"g_min_y\")\n",
        "g_max_y = model.new_int_var(core_y_min, core_y_max, \"g_max_y\")\n",
        "\n",
        "model.add_min_equality(g_min_x, [n['x'] for n in nodes.values()])\n",
        "model.add_max_equality(g_max_x, [n['x'] + n['w'] for n in nodes.values()])\n",
        "model.add_min_equality(g_min_y, [n['y'] for n in nodes.values()])\n",
        "model.add_max_equality(g_max_y, [n['y'] + n['h'] for n in nodes.values()])\n",
        "\n",
        "occupied_span = (g_max_x - g_min_x) + (g_max_y - g_min_y)\n",
        "model.minimize(sum(net_costs) + occupied_span)\n",
        "print(\"Objectives added.\")"
      ]
    },
